NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Base URL của backend (dùng để build callback/webhook URL)
APP_BASE_URL=http://localhost:4000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/SpaBooking
MONGODB_DB_NAME=SpaBooking

# Auth
JWT_SECRET=change_me

# PayOS (điền thật khi deploy)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=http://localhost:5173
PAYOS_CANCEL_URL=http://localhost:5173

# PAYOS_WEBHOOK_URL=https://your-domain.com/api/webhooks/payos

# Booking rules
CUSTOMER_CANCEL_CUTOFF_MINUTES=120

# Email (SMTP) - dùng Gmail App Password hoặc SMTP provider khác
EMAIL_PROVIDER=smtp
EMAIL_FROM="LumiX <your_email@gmail.com>"
EMAIL_API_KEY=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_SMTP_USER=your_email@gmail.com
